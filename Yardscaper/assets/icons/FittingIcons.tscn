[sub_resource type="GDScript" id="GDScript_i8r4u"]
script/source = "extends Node

@export var CUSTOM         : Texture2D = null
@export var COUPLING       : Texture2D = null
@export var ELBOW_90       : Texture2D = null
@export var ELBOW_45       : Texture2D = null
@export var TEE_BRANCH_OUT : Texture2D = null
@export var TEE_BRANCH_IN  : Texture2D = null
@export var TEE_RUN        : Texture2D = null

func from_type(fitting_type: PipeTables.FittingType) -> Texture2D:
	match fitting_type:
		PipeTables.FittingType.NONE:           return null
		PipeTables.FittingType.CUSTOM:         return CUSTOM
		PipeTables.FittingType.COUPLING:       return COUPLING
		PipeTables.FittingType.ELBOW_90:       return ELBOW_90
		PipeTables.FittingType.ELBOW_45:       return ELBOW_45
		PipeTables.FittingType.TEE_BRANCH_OUT: return TEE_BRANCH_OUT
		PipeTables.FittingType.TEE_BRANCH_IN:  return TEE_BRANCH_IN
		PipeTables.FittingType.TEE_RUN:        return TEE_RUN
	push_warning(\"unsupported fitting type '%s'\" % [fitting_type])
	return null
"

[node name="FittingIcons" type="Node" unique_id=1969766493]
script = SubResource("GDScript_i8r4u")
CUSTOM = ExtResource("1_ylrvj")
COUPLING = ExtResource("2_r1y3s")
ELBOW_90 = ExtResource("1_6dcqy")
ELBOW_45 = ExtResource("2_k8v7w")
TEE_BRANCH_OUT = ExtResource("4_sp6dl")
TEE_BRANCH_IN = ExtResource("5_ulk0l")
TEE_RUN = ExtResource("2_hfp55")
